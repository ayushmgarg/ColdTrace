APP_NAME=ColdTrace DC
APP_TAGLINE=Distributed Vaccine Cold Chain Monitoring Platform
AUTH_PROVIDER=local
JWT_SECRET=change-this-secret-before-demo
TOKEN_TTL_MINUTES=720

DEMO_ADMIN_PASSWORD=Admin@123
DEMO_MANAGER_PASSWORD=Manager@123
DEMO_SUPERVISOR_PASSWORD=Supervisor@123
DEMO_VACCINATOR_PASSWORD=Vaccinator@123

COLDCHAIN_DB_PATH=./coldchain.db
CLOUD_API_BASE=http://127.0.0.1:8000
SIMULATOR_INTERVAL_SECONDS=3
SIMULATE_GATEWAY_OUTAGES=true
SIMULATED_OUTAGE_RATE=0.18

# Fill in real keys to enable SMS / email alerts
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

SENDGRID_API_KEY=
EMAIL_FROM=coldtrace@example.com
EMAIL_FROM_NAME=ColdTrace DC

# Fill in for live Mapbox map (otherwise SVG fallback is shown)
MAPBOX_ACCESS_TOKEN=
MAPBOX_STYLE=mapbox://styles/mapbox/dark-v11
